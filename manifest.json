{
  "manifest_version": 3,
  "name": "AI Phishing Defender",
  "version": "1.0.0",
  "description": "Bảo vệ khỏi link lừa đảo",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_end"
  }],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}